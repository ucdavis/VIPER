{
    "name": "vueapp",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "24.14.1"
    },
    "scripts": {
        "dev": "vite",
        "dev:typed": "concurrently --names \"VITE,TYPES\" --prefix-colors \"green,blue\" \"vite\" \"vue-tsc --noEmit --watch\"",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check": "vue-tsc --build",
        "type-check:watch": "vue-tsc --noEmit --watch",
        "lint": "eslint . --cache --cache-strategy content --cache-location .eslintcache",
        "lint:fix": "eslint . --fix --cache --cache-strategy content --cache-location .eslintcache",
        "watch": "node vite-watch.js",
        "build-dev": "run-p type-check \"build-only-dev {@}\" --",
        "build-only-dev": "cross-env VITE_API_URL=/api/ VITE_VIPER_HOME=/ VITE_VIPER_1_HOME=http://localhost/ vite build",
        "build-test": "run-p type-check \"build-only-test {@}\" --",
        "build-only-test": "vite build --mode test",
        "test": "vitest",
        "test:run": "vitest run"
    },
    "dependencies": {
        "@quasar/extras": "^1.16.12",
        "@vueuse/core": "^14.0.0",
        "chart.js": "^4.5.1",
        "inflection": "^3.0.2",
        "pinia": "^3.0.3",
        "quasar": "^2.19.1",
        "vue": "^3.5.30",
        "vue-chartjs": "^5.3.3",
        "vue-draggable-plus": "^0.6.1",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "^1.9.1",
        "@eslint/js": "^10.0.0",
        "@pinia/testing": "^1.0.3",
        "@quasar/app-vite": "^2.5.4",
        "@quasar/vite-plugin": "^1.9.0",
        "@tsconfig/node24": "^24.0.4",
        "@types/inflection": "^2.0.0",
        "@types/node": "~25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.56.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/coverage-v8": "^4.1.1",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.1",
        "chokidar": "^5.0.0",
        "concurrently": "^9.2.1",
        "cross-env": "^10.0.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-harlanzw": "^0.11.0",
        "eslint-plugin-vue": "^10.8.0",
        "eslint-plugin-vuejs-accessibility": "^2.5.0",
        "glob": "^13.0.0",
        "globals": "^17.4.0",
        "happy-dom": "^20.8.8",
        "lodash-es": "^4.17.21",
        "npm-run-all2": "^8.0.4",
        "sass": "^1.98.0",
        "tree-kill": "^1.2.2",
        "typescript": "^5.9.2",
        "vite": "^8.0.2",
        "vite-plugin-vue-inspector": "^5.3.2",
        "vitest": "^4.0.0",
        "vue-tsc": "^3.2.6"
    },
    "overrides": {
        "@codecov/vite-plugin": {
            "vite": "$vite"
        }
    },
    "volta": {
        "node": "24.14.1",
        "npm": "11.12.0"
    }
}
