{
    "name": "vueapp",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "24.14.1"
    },
    "scripts": {
        "dev": "vite",
        "dev:typed": "concurrently --names \"VITE,TYPES\" --prefix-colors \"green,blue\" \"vite\" \"vue-tsc --noEmit --watch\"",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check": "vue-tsc --build",
        "type-check:watch": "vue-tsc --noEmit --watch",
        "lint": "eslint . --cache --cache-strategy content --cache-location .eslintcache",
        "lint:fix": "eslint . --fix --cache --cache-strategy content --cache-location .eslintcache",
        "watch": "node vite-watch.js",
        "build-dev": "run-p type-check \"build-only-dev {@}\" --",
        "build-only-dev": "cross-env VITE_API_URL=/api/ VITE_VIPER_HOME=/ VITE_VIPER_1_HOME=http://localhost/ vite build",
        "build-test": "run-p type-check \"build-only-test {@}\" --",
        "build-only-test": "vite build --mode test",
        "test": "vitest",
        "test:run": "vitest run"
    },
    "dependencies": {
        "@vueuse/core": "^14.0.0",
        "chart.js": "^4.4.3",
        "inflection": "^3.0.2",
        "pinia": "^3.0.3",
        "quasar": "^2.19.3",
        "vue": "^3.5.33",
        "vue-chartjs": "^5.3.1",
        "vue-draggable-plus": "^0.6.1",
        "vue-router": "^5.0.6"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "^2.0.1",
        "@eslint/js": "^10.0.0",
        "@quasar/app-vite": "^2.6.0",
        "@quasar/vite-plugin": "^1.9.0",
        "@tsconfig/node24": "^24.0.4",
        "@types/inflection": "^2.0.0",
        "@types/node": "~25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.56.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vitest/coverage-v8": "^4.1.5",
        "@vue/test-utils": "^2.4.8",
        "@vue/tsconfig": "^0.9.1",
        "chokidar": "^5.0.0",
        "concurrently": "^9.2.1",
        "cross-env": "^10.0.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-harlanzw": "^0.12.1",
        "eslint-plugin-vue": "^10.9.0",
        "eslint-plugin-vuejs-accessibility": "^2.5.0",
        "glob": "^13.0.6",
        "globals": "^17.5.0",
        "happy-dom": "^20.9.0",
        "lodash-es": "^4.17.21",
        "npm-run-all2": "^8.0.4",
        "oxfmt": "^0.46.0",
        "oxlint-tsgolint": "^0.21.1",
        "tree-kill": "^1.2.2",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-vue-inspector": "^5.3.2",
        "vitest": "^4.0.0",
        "vue-tsc": "^3.2.7"
    },
    "overrides": {
        "@codecov/vite-plugin": {
            "vite": "$vite"
        }
    },
    "volta": {
        "node": "24.14.1",
        "npm": "11.12.0"
    }
}
